@Article{SystemicSaturaKrautb2016,
  abstract = {Serum lysophosphatidylcholine (LPC) is described to decline in patients with chronic liver diseases. Here it was evaluated which of the LPC species are associated with liver function. LPC species were quantified by direct flow-injection electrospray ionization tandem mass spectrometry in serum of 45 patients with mainly alcoholic liver cirrhosis. Saturated LPC is 52.1 (31.7-110.0) {\textdollar \textbackslash mu\textdollar }mol/l in serum of patients with CHILD-PUGH score C (decompensated liver cirrhosis) and significantly lower compared to patients with well-compensated disease (CHILD-PUGH score A) with 114.1 (12.3-401.4) {\textdollar \textbackslash mu\textdollar }mol/l. Mono- and polyunsaturated LPC are not changed in these groups. Saturated LPC is negatively correlated with the model for end-stage liver disease score, bilirubin and galectin-3 and positively with Quick prothrombin time. Ascites and varices are complications of liver cirrhosis. Saturated LPC does, however, not correlate with hepatic venous pressure gradient, ascites volume and variceal size. Unexpectedly, saturated LPC measured in serum of 42 patients declines from 88.4 (27.8-177.5) {\textdollar \textbackslash mu\textdollar }mol/l to 72.4 (27.6-141.8) {\textdollar \textbackslash mu\textdollar }mol/l shortly after transjugular intrahepatic portosystemic shunt implantation. Hepatic vein saturated LPC (82.3 (12.4-161.7) {\textdollar \textbackslash mu\textdollar }mol/l) is higher than portal vein levels (78.8 (10.1-161.0) {\textdollar \textbackslash mu\textdollar }mol/l) suggesting hepatic release of this lipid species. Current data demonstrate that systemic saturated LPC species are reduced in patients with decompensated liver cirrhosis and associated with mortality risk.},
  author = {Sabrina Krautbauer and Kristina Eisinger and Reiner Wiest and Gerhard Liebisch and Christa Buechler},
  doi = {10.1016/j.prostaglandins.2016.06.001},
  issn = {1098-8823},
  journal = {Prostaglandins \textbackslash \& Other Lipid Mediators},
  keywords = {Adult,Aged,{Aged, 80 and over},Ascites,Blood Proteins,CHILD-PUGH score,Female,Galectin 3,Galectin-3,Galectins,Hepatic Veins,Humans,Liver,{Liver Cirrhosis, Alcoholic},Lysophosphatidylcholines,Male,Middle Aged,Phosphatidylcholine,Prothrombin Time,Severity of Illness Index},
  langid = {english},
  month = {July},
  pages = {27--33},
  title = {Systemic Saturated Lysophosphatidylcholine Is Associated with Hepatic Function in Patients with Liver Cirrhosis},
  volume = {124},
  year = {2016},
}

