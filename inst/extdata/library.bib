@Article{IonIdentityMoSchmid2021,
  abstract = {Abstract             Molecular networking connects mass spectra of molecules based on the similarity of their fragmentation patterns. However, during ionization, molecules commonly form multiple ion species with different fragmentation behavior. As a result, the fragmentation spectra of these ion species often remain unconnected in tandem mass spectrometry-based molecular networks, leading to redundant and disconnected sub-networks of the same compound classes. To overcome this bottleneck, we develop Ion Identity Molecular Networking (IIMN) that integrates chromatographic peak shape correlation analysis into molecular networks to connect and collapse different ion species of the same molecule. The new feature relationships improve network connectivity for structurally related molecules, can be used to reveal unknown ion-ligand complexes, enhance annotation within molecular networks, and facilitate the expansion of spectral reference libraries. IIMN is integrated into various open source feature finding tools and the GNPS environment. Moreover, IIMN-based spectral libraries with a broad coverage of ion species are publicly available.},
  author = {Robin Schmid and Daniel Petras and Louis-F\'{e}lix Nothias and Mingxun Wang and Allegra T. Aron and Annika Jagels and Hiroshi Tsugawa and Johannes Rainer and Mar Garcia-Aloy and Kai D\"{u}hrkop and Ansgar Korf and Tom\'{a}\v{s} Pluskal and Zden\v{e}k Kamen\'{\i}k and Alan K. Jarmusch and Andr\'{e}s Mauricio {Caraballo-Rodr\textbackslash{\\textquotesingle{} g}uez} and Kelly C. Weldon and Melissa Nothias-Esposito and Alexander A. Aksenov and Anelize Bauermeister and Andrea {Albarracin Orio} and Carlismari O. Grundmann and Fernando Vargas and Irina Koester and Julia M. Gauglitz and Emily C. Gentry and Yannick H\"{o}velmann and Svetlana A. Kalinina and Matthew A. Pendergraft and Morgan Panitchpakdi and Richard Tehan and Audrey {Le Gouellec} and Gajender Aleti and Helena {Mannochio Russo} and Birgit Arndt and Florian H\"{u}bner and Heiko Hayen and Hui Zhi and Manuela Raffatellu and Kimberly A. Prather and Lihini I. Aluwihare and Sebastian B\"{o}cker and Kerry L. McPhail and Hans-Ulrich Humpf and Uwe Karst and Pieter C. Dorrestein},
  doi = {10.1038/s41467-021-23953-9},
  issn = {2041-1723},
  journal = {Nature Communications},
  langid = {english},
  month = {December},
  number = {1},
  pages = {3832},
  title = {Ion Identity Molecular Networking for Mass Spectrometry-Based Metabolomics in the GNPS Environment},
  urldate = {2021-11-15},
  volume = {12},
  year = {2021},
}

