  keywords = {1-Acylglycerophosphocholine O-Acyltransferase,Acyl Coenzyme A,Acylation,Animals,Catalytic Domain,Chickens,Cryoelectron Microscopy,{Crystallography, X-Ray},Lysophosphatidylcholines,{Models, Molecular},Phospholipids,Protein Multimerization,Structure-Activity Relationship,Substrate Specificity},
  langid = {english},
  month = {November},
  number = {1},
  pages = {6869},
  title = {The Structural Basis for the Phospholipid Remodeling by Lysophosphatidylcholine Acyltransferase 3},
  volume = {12},
  year = {2021},
}

