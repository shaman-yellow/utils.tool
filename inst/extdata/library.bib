@Article{IfnGAbrogatChen2010,
  abstract = {An important mechanism by which IFN-{\textdollar \textbackslash gamma\textdollar } primes macrophages for enhanced innate immune responses is abrogation of feedback inhibitory pathways. Accordingly, IFN-{\textdollar \textbackslash gamma\textdollar } abrogates endotoxin tolerance, a major negative feedback loop that silences expression of inflammatory cytokine genes in macrophages previously exposed to endotoxin/Toll-like receptor (TLR) ligands. Mechanisms by which IFN-{\textdollar \textbackslash gamma\textdollar } inhibits endotoxin tolerance have not been elucidated. Here, we show that pretreatment with IFN-{\textdollar \textbackslash gamma\textdollar } prevented tolerization of primary human monocytes and restored TLR4-mediated induction of various proinflammatory cytokines, including IL-6 and TNF{\textdollar \textbackslash alpha\textdollar }. Surprisingly, IFN-{\textdollar \textbackslash gamma\textdollar } did not alter proximal TLR4 signaling defects in tolerized monocytes. Instead, IFN-{\textdollar \textbackslash gamma\textdollar } blocked tolerance-associated down-regulation of               IL6               and               TNF               transcription, RNA polymerase II recruitment, and NF-{\textdollar \textbackslash kappa\textdollar }B and CCAAT/enhancer-binding protein {\textdollar \textbackslash beta\textdollar } transcription factor binding to the               IL6               and               TNF               promoters in tolerized monocytes. The mechanism by which IFN-{\textdollar \textbackslash gamma\textdollar } restored               IL6               expression was by facilitating TLR4-induced recruitment of chromatin remodeling machinery to the               IL6               promoter and promoting               IL6               locus accessibility in tolerized monocytes. Our results suggest that IFN-{\textdollar \textbackslash gamma\textdollar } overcomes endotoxin tolerance by facilitating TLR-induced chromatin remodeling to allow expression of proinflammatory genes. These results identify a mechanism by which IFN-{\textdollar \textbackslash gamma\textdollar } promotes activation of macrophages and highlight the importance of chromatin remodeling and transcriptional control in the regulation of inflammatory cytokine production in tolerant and activated macrophages.},
  author = {Janice Chen and Lionel B. Ivashkiv},
  doi = {10.1073/pnas.1007816107},
  issn = {0027-8424, 1091-6490},
  journal = {Proceedings of the National Academy of Sciences},
  langid = {english},
  month = {November},
  number = {45},
  pages = {19438--19443},
  title = {IFN-\textdollar \gamma \textdollar  Abrogates Endotoxin Tolerance by Facilitating Toll-like Receptor-Induced Chromatin Remodeling},
  urldate = {2023-04-02},
  volume = {107},
  year = {2010},
}

