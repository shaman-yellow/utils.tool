@Article{DeepLearningBWilhel2021,
  abstract = {Abstract             Characterizing the human leukocyte antigen (HLA) bound ligandome by mass spectrometry (MS) holds great promise for developing vaccines and drugs for immune-oncology. Still, the identification of non-tryptic peptides presents substantial computational challenges. To address these, we synthesized and analyzed {\textdollar >\textdollar }300,000 peptides by multi-modal LC-MS/MS within the ProteomeTools project representing HLA class I \textbackslash \& II ligands and products of the proteases AspN and LysN. The resulting data enabled training of a single model using the deep learning framework Prosit, allowing the accurate prediction of fragment ion spectra for tryptic and non-tryptic peptides. Applying Prosit demonstrates that the identification of HLA peptides can be improved up to 7-fold, that 87\textbackslash \% of the proposed proteasomally spliced HLA peptides may be incorrect and that dozens of additional immunogenic neo-epitopes can be identified from patient tumors in published data. Together, the provided peptides, spectra and computational tools substantially expand the analytical depth of immunopeptidomics workflows.},
  author = {Mathias Wilhelm and Daniel P. Zolg and Michael Graber and Siegfried Gessulat and Tobias Schmidt and Karsten Schnatbaum and Celina Schwencke-Westphal and Philipp Seifert and Niklas {de Andrade Kr\"{a}tzig} and Johannes Zerweck and Tobias Knaute and Eva Br\"{a}unlein and Patroklos Samaras and Ludwig Lautenbacher and Susan Klaeger and Holger Wenschuh and Roland Rad and Bernard Delanghe and Andreas Huhmer and Steven A. Carr and Karl R. Clauser and Angela M. Krackhardt and Ulf Reimer and Bernhard Kuster},
  doi = {10.1038/s41467-021-23713-9},
  issn = {2041-1723},
  journal = {Nature Communications},
  langid = {english},
  month = {December},
  number = {1},
  pages = {3346},
  title = {Deep Learning Boosts Sensitivity of Mass Spectrometry-Based Immunopeptidomics},
  urldate = {2022-07-18},
  volume = {12},
  year = {2021},
}

