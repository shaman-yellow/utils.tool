  month = {January},
  number = {Database issue},
  pages = {D456-463},
  shorttitle = {The {{ChEBI}} Reference Database and Ontology for Biologically Relevant Chemistry},
  title = {The ChEBI Reference Database and Ontology for Biologically Relevant Chemistry: Enhancements for 2013},
  volume = {41},
  year = {2013},
