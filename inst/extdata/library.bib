  keywords = {Antioxidants,Butylated Hydroxytoluene,Eucommia ulmoides seed oil,Eucommiaceae,Molecular simulation,Natural antioxidants,Oxidation-Reduction,Oxidative stability,Oxidative Stress,Plant Oils},
  langid = {english},
  month = {July},
  pages = {132640},
  shorttitle = {Effects of Natural Antioxidants on the Oxidative Stability of {{Eucommia}} Ulmoides Seed Oil},
  title = {Effects of Natural Antioxidants on the Oxidative Stability of Eucommia Ulmoides Seed Oil: Experimental and Molecular Simulation Investigations},
  volume = {383},
