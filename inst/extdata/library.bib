@Article{ExtendingAndIBlanco2023,
  abstract = {<jats:title>Abstract</jats:title><jats:p>Metagenomic assembly enables new organism discovery from microbial communities, but it can only capture few abundant organisms from most metagenomes. Here we present MetaPhlAn 4, which integrates information from metagenome assemblies and microbial isolate genomes for more comprehensive metagenomic taxonomic profiling. From a curated collection of 1.01\hspace{0.167em}M prokaryotic reference and metagenome-assembled genomes, we define unique marker genes for 26,970 species-level genome bins, 4,992 of them taxonomically unidentified at the species level. MetaPhlAn 4 explains \textasciitilde 20\% more reads in most international human gut microbiomes and \&gt;40\% in less-characterized environments such as the rumen microbiome and proves more accurate than available alternatives on synthetic evaluations while also reliably quantifying organisms with no cultured isolates. Application of the method to \&gt;24,500 metagenomes highlights previously undetected species to be strong biomarkers for host conditions and lifestyles in human and mouse microbiomes and shows that even previously uncharacterized species can be genetically profiled at the resolution of single microbial strains.</jats:p>},
  author = {Aitor Blanco-M\'{\i}guez and Francesco Beghini and Fabio Cumbo and Lauren J. McIver and Kelsey N. Thompson and Moreno Zolfo and Paolo Manghi and Leonard Dubois and Kun D. Huang and Andrew Maltez Thomas and William A. Nickols and Gianmarco Piccinno and Elisa Piperni and Michal Pun\v{c}och\'{a}\v{r} and Mireia Valles-Colomer and Adrian Tett and Francesca Giordano and Richard Davies and Jonathan Wolf and Sarah E. Berry and Tim D. Spector and Eric A. Franzosa and Edoardo Pasolli and Francesco Asnicar and Curtis Huttenhower and Nicola Segata},
  doi = {10.1038/s41587-023-01688-w},
  issue = {11},
  journal = {Nature Biotechnology},
  language = {en},
  month = {11},
  pages = {1633--1644},
  publisher = {Springer Science and Business Media LLC},
  title = {Extending and improving metagenomic taxonomic profiling with uncharacterized species using MetaPhlAn 4},
