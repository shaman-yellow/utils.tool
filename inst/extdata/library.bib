  journal = {Immunological Reviews},
  keywords = {Amino Acid Sequence,Animals,Antigen Presentation,Chromosome Mapping,Cysteine Endopeptidases,Enzyme Activation,Gene Expression Regulation,Histocompatibility Antigens Class I,Humans,Interferon-gamma,Ligands,Molecular Sequence Data,Multienzyme Complexes,Muscle Proteins,Proteasome Endopeptidase Complex,Protein Conformation,Proteins,Ubiquitins},
  langid = {english},
  month = {June},
  pages = {161--176},
  shorttitle = {The {{MHC}} Class {{I}} Ligand-Generating System},
  title = {The MHC Class I Ligand-Generating System: Roles of Immunoproteasomes and the Interferon-Gamma-Inducible Proteasome Activator PA28},
  volume = {163},
  year = {1998},
}

