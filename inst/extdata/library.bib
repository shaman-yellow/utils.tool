@Article{RobustReproduBian2020,
  abstract = {Abstract             Nano-flow liquid chromatography tandem mass spectrometry (nano-flow LC\textbackslash textendash MS/MS) is the mainstay in proteome research because of its excellent sensitivity but often comes at the expense of robustness. Here we show that micro-flow LC\textbackslash textendash MS/MS using a 1\textbackslash ,\textbackslash texttimes\textbackslash ,150\textbackslash ,mm column shows excellent reproducibility of chromatographic retention time ({\textdollar <\textdollar }0.3\textbackslash \% coefficient of variation, CV) and protein quantification ({\textdollar <\textdollar }7.5\textbackslash \% CV) using data from {\textdollar >\textdollar }2000 samples of human cell lines, tissues and body fluids. Deep proteome analysis identifies {\textdollar >\textdollar }9000 proteins and {\textdollar >\textdollar }120,000 peptides in 16\textbackslash ,h and sample multiplexing using tandem mass tags increases throughput to 11 proteomes in 16\textbackslash ,h. The system identifies {\textdollar >\textdollar }30,000 phosphopeptides in 12\textbackslash ,h and protein-protein or protein-drug interaction experiments can be analyzed in 20\textbackslash ,min per sample. We show that the same column can be used to analyze {\textdollar >\textdollar }7500 samples without apparent loss of performance. This study demonstrates that micro-flow LC\textbackslash textendash MS/MS is suitable for a broad range of proteomic applications.},
  author = {Yangyang Bian and Runsheng Zheng and Florian P. Bayer and Cassandra Wong and Yun-Chien Chang and Chen Meng and Daniel P. Zolg and Maria Reinecke and Jana Zecha and Svenja Wiechmann and Stephanie Heinzlmeir and Johannes Scherr and Bernhard Hemmer and Mike Baynham and Anne-Claude Gingras and Oleksandr Boychenko and Bernhard Kuster},
  doi = {10.1038/s41467-019-13973-x},
  issn = {2041-1723},
  journal = {Nature Communications},
  langid = {english},
  month = {December},
  number = {1},
  pages = {157},
  title = {Robust, Reproducible and Quantitative Analysis of Thousands of Proteomes by Micro-Flow LC\textendash MS/MS},
  urldate = {2022-07-18},
  volume = {11},
  year = {2020},
}

